# ============================================================
# HAYO AI — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم
# cp .env.example .env
# ============================================================

# ─── قاعدة البيانات PostgreSQL ───
DATABASE_URL=postgresql://user:password@host:5432/hayo_ai

# ─── جلسة التطبيق (أي نص عشوائي طويل) ───
SESSION_SECRET=your-random-session-secret-here

# ─── رابط التطبيق (غيّره حسب بيئتك) ───
APP_URL=https://your-app-domain.up.railway.app

# ─── Telegram Bot (البوت الرئيسي — HAYO_AI_Signals_bot) ───
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_CHAT_ID=34498339

# ─── Telegram Bridge Bot (البوت المساعد — ALEPPO_CANDLES6_bot) ───
TELEGRAM_BRIDGE_BOT_TOKEN=your-bridge-bot-token

# ─── TwelveData API (بيانات الأسواق — 6 مفاتيح) ───
TWELVE_DATA_API_KEY=your-primary-key
TWELVE_DATA_API_KEYS=key1,key2,key3,key4,key5,key6

# ─── Google Gemini AI ───
GOOGLE_API_KEY3=your-gemini-api-key

# ─── OpenAI (GPT-4o) ───
OPENAI_API_KEY=your-openai-api-key

# ─── Anthropic (Claude) ───
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── DeepSeek AI ───
DEEPSEEK_API_KEY=your-deepseek-api-key

# ─── المنفذ (Railway يضبطه تلقائياً) ───
PORT=8080

# ─── بيئة التشغيل ───
NODE_ENV=production
